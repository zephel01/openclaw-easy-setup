# =============================================================================
# openclaw-easy-setup — Environment Variables
# =============================================================================
# cp .env.example .env   ← Copy first, then edit
# NEVER commit .env to version control!
#
# How it works:
#   - All variables in this file are passed to the OpenClaw container
#     via `env_file` in docker-compose.yml
#   - Just uncomment and fill in the providers you use
#   - Base URLs marked "required" MUST be set for that provider to work
#
# ── API Keys / Tokens — secrets/ ディレクトリを推奨 ──────────────────
#   API キーやトークンは .env ではなく secrets/ ディレクトリに
#   個別ファイルとして配置することを推奨します。
#
#   例: echo "sk-ant-api03-xxxxx" > secrets/ANTHROPIC_API_KEY
#
#   secrets/ のファイルは docker inspect に露出せず、
#   誤って git commit するリスクも低くなります。
#   詳しくは secrets/README.md を参照してください。
#
#   ※ .env に API キーを書いても動作しますが、セキュリティ上
#     secrets/ を使う方が安全です。同名の変数がある場合、
#     secrets/ の値が .env を上書きします。
# =============================================================================


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  AI / LLM Providers                                                     ║
# ║  Uncomment the providers you want to use.                               ║
# ║  At minimum, configure one provider OR use Ollama (no key needed).      ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ── Anthropic Claude ─────────────────────────────────────────────────────────
# Models: claude-3.5-sonnet, claude-3-opus, claude-3-haiku, etc.
# Get key: https://console.anthropic.com/
#ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# ── OpenAI ───────────────────────────────────────────────────────────────────
# Models: gpt-4o, gpt-4, o1, etc.
# Get key: https://platform.openai.com/
#OPENAI_API_KEY=sk-xxxxx
#OPENAI_BASE_URL=https://api.openai.com/v1

# ── Google Gemini ────────────────────────────────────────────────────────────
# Models: gemini-pro, gemini-flash, gemini-ultra
# Get key: https://aistudio.google.com/
#GOOGLE_API_KEY=AIzaSy-xxxxx
# or:
#GEMINI_API_KEY=AIzaSy-xxxxx

# ── Groq ─────────────────────────────────────────────────────────────────────
# Ultra-fast inference for open-source models
# Get key: https://console.groq.com/
#GROQ_API_KEY=gsk_xxxxx

# ── MiniMax ──────────────────────────────────────────────────────────────────
# Base URL is REQUIRED for MiniMax
#MINIMAX_API_KEY=xxxxx
#MINIMAX_BASE_URL=https://api.minimax.io/anthropic

# ── Moonshot / Kimi ──────────────────────────────────────────────────────────
# Base URL is REQUIRED
# Get key: https://platform.moonshot.cn/
#MOONSHOT_API_KEY=xxxxx
#MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
# Alternative variable name:
#KIMI_API_KEY=xxxxx

# ── Qwen (通义千问 / Alibaba) ────────────────────────────────────────────────
#QWEN_API_KEY=xxxxx
#QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Qianfan (千帆 / Baidu) ──────────────────────────────────────────────────
#QIANFAN_API_KEY=xxxxx
#QIANFAN_SECRET_KEY=xxxxx

# ── GLM / Zhipu AI (智谱) ───────────────────────────────────────────────────
#GLM_API_KEY=xxxxx
#GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ── Z.AI ─────────────────────────────────────────────────────────────────────
# Base URL is REQUIRED
#ZAI_API_KEY=xxxxx
#ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4

# ── Xiaomi MiMo ──────────────────────────────────────────────────────────────
#MIMO_API_KEY=xxxxx

# ── Cerebras ─────────────────────────────────────────────────────────────────
# Fast inference
# Base URL is REQUIRED
#CEREBRAS_API_KEY=xxxxx
#CEREBRAS_BASE_URL=https://api.cerebras.ai/v1

# ── OpenRouter ───────────────────────────────────────────────────────────────
# Gateway to 100+ models (Llama, Mistral, Claude, etc.)
# Get key: https://openrouter.ai/
#OPENROUTER_API_KEY=xxxxx

# ── Together AI ──────────────────────────────────────────────────────────────
# Open-source model hosting
# Get key: https://api.together.xyz/
#TOGETHER_API_KEY=xxxxx
#TOGETHER_BASE_URL=https://api.together.xyz/v1

# ── Hugging Face ─────────────────────────────────────────────────────────────
#HUGGINGFACE_API_KEY=hf_xxxxx

# ── Synthetic ────────────────────────────────────────────────────────────────
# Base URL is REQUIRED
#SYNTHETIC_API_KEY=xxxxx
#SYNTHETIC_BASE_URL=https://api.synthetic.new/anthropic

# ── Venice AI ────────────────────────────────────────────────────────────────
# Privacy-focused inference
#VENICE_API_KEY=xxxxx

# ── Perplexity Sonar ─────────────────────────────────────────────────────────
# Search-integrated AI
#PERPLEXITY_API_KEY=pplx-xxxxx

# ── OpenCode Zen ─────────────────────────────────────────────────────────────
#OPENCODE_API_KEY=xxxxx

# ── Amazon Bedrock ───────────────────────────────────────────────────────────
# Uses standard AWS credentials
#AWS_ACCESS_KEY_ID=AKIA-xxxxx
#AWS_SECRET_ACCESS_KEY=xxxxx
#AWS_REGION=us-east-1

# ── Grok / X.AI ─────────────────────────────────────────────────────────────
#XAI_API_KEY=xxxxx

# ── OpenAI-compatible custom endpoint ────────────────────────────────────────
# For any provider with an OpenAI-compatible API (vLLM, LM Studio, etc.)
#CUSTOM_LLM_API_KEY=xxxxx
#CUSTOM_LLM_BASE_URL=http://localhost:8000/v1


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Messaging Platforms                                                     ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ── Telegram ─────────────────────────────────────────────────────────────────
# Get token from @BotFather
#TELEGRAM_BOT_TOKEN=123456:ABCdef-xxxxx

# ── Slack ────────────────────────────────────────────────────────────────────
# https://api.slack.com/apps
#SLACK_BOT_TOKEN=xoxb-xxxxx
#SLACK_APP_TOKEN=xapp-xxxxx

# ── Discord ──────────────────────────────────────────────────────────────────
# https://discord.com/developers/applications
#DISCORD_BOT_TOKEN=xxxxx

# ── LINE ─────────────────────────────────────────────────────────────────────
# https://developers.line.biz/
#LINE_CHANNEL_ACCESS_TOKEN=xxxxx
#LINE_CHANNEL_SECRET=xxxxx

# ── Matrix ───────────────────────────────────────────────────────────────────
#MATRIX_HOMESERVER=https://matrix.example.com
#MATRIX_ACCESS_TOKEN=xxxxx
#MATRIX_USER_ID=@bot:example.com
#MATRIX_PASSWORD=xxxxx

# ── Mattermost ───────────────────────────────────────────────────────────────
#MATTERMOST_BOT_TOKEN=xxxxx
#MATTERMOST_URL=https://mattermost.example.com

# ── Feishu (飞书 / Lark) ────────────────────────────────────────────────────
#FEISHU_APP_ID=xxxxx
#FEISHU_APP_SECRET=xxxxx

# ── Twitch ───────────────────────────────────────────────────────────────────
#OPENCLAW_TWITCH_ACCESS_TOKEN=oauth:xxxxx

# ── Zalo ─────────────────────────────────────────────────────────────────────
#ZALO_BOT_TOKEN=xxxxx

# ── Nostr ────────────────────────────────────────────────────────────────────
#NOSTR_PRIVATE_KEY=nsec1xxxxx

# ── IRC ──────────────────────────────────────────────────────────────────────
#IRC_HOST=irc.libera.chat
#IRC_PORT=6697
#IRC_TLS=true
#IRC_NICK=openclaw-bot
#IRC_PASSWORD=
#IRC_CHANNELS=#general


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Web Search                                                              ║
# ║  Auto-detected when set. Just uncomment the one(s) you want.            ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

#BRAVE_API_KEY=BSA-xxxxx
#PERPLEXITY_API_KEY=pplx-xxxxx
# GEMINI_API_KEY is shared with the LLM provider above
# XAI_API_KEY is shared with Grok above


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Browser Automation & Media                                              ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

#BROWSERLESS_API_KEY=xxxxx
#BROWSERBASE_API_KEY=xxxxx
#FIRECRAWL_API_KEY=xxxxx
#ELEVENLABS_API_KEY=xxxxx
#DEEPGRAM_API_KEY=xxxxx


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  OpenClaw Gateway Security                                               ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

OPENCLAW_AUTH_MODE=token
OPENCLAW_AUTH_TOKEN=
OPENCLAW_DM_POLICY=pairing
OPENCLAW_REQUIRE_MENTION=true
OPENCLAW_DENY_TOOLS=exec,browser,cron


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Ollama (Local LLM)                                                      ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

OLLAMA_DEFAULT_MODEL=llama3.2
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  Network / Proxy                                                         ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

#HTTP_PROXY=http://proxy.example.com:8080
#HTTPS_PROXY=http://proxy.example.com:8080
#NO_PROXY=localhost,127.0.0.1,ollama


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  General                                                                 ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

TZ=Asia/Tokyo
