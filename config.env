# =============================================================================
# openclaw-easy-setup — Configuration File
# =============================================================================
# Copy this file and edit values before running setup.sh or setup.ps1
#
# Usage:
#   macOS/Linux : ./setup.sh [--with-clawx] [--config config.env]
#   Windows     : .\setup.ps1 [-WithClawX] [-ConfigFile config.env]
# =============================================================================

# ---------------------------------------------------------------------------
# Node.js
# ---------------------------------------------------------------------------
# Desired Node.js major version (OpenClaw requires >= 22)
NODE_MAJOR_VERSION=22

# ---------------------------------------------------------------------------
# OpenClaw
# ---------------------------------------------------------------------------
# Installation method: "npm" (official installer) | "docker"
# Note: "npm" uses the official install.sh script
OPENCLAW_INSTALL_METHOD=docker

# Pin a specific OpenClaw version (leave empty for latest stable)
OPENCLAW_VERSION=

# Gateway bind address — "loopback" is strongly recommended for security
OPENCLAW_GATEWAY_BIND=loopback

# Gateway port (default: 18789)
OPENCLAW_GATEWAY_PORT=18789

# Authentication mode: "token" (recommended) | "none"
OPENCLAW_AUTH_MODE=token

# Auth token — auto-generated if left empty
OPENCLAW_AUTH_TOKEN=

# DM policy: "pairing" (safe default) | "open"
OPENCLAW_DM_POLICY=pairing

# Require @mention in group channels: true | false
OPENCLAW_REQUIRE_MENTION=true

# Deny dangerous tools by default (comma-separated): exec,browser,cron
OPENCLAW_DENY_TOOLS=exec,browser,cron

# ---------------------------------------------------------------------------
# AI Provider (configure at least one)
# ---------------------------------------------------------------------------
# Provider: "anthropic" | "openai" | "ollama" | ""
AI_PROVIDER=

# API keys (stored in ~/.openclaw/.env with 600 permissions)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ollama endpoint (only if AI_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# ---------------------------------------------------------------------------
# ClawX (optional desktop GUI)
# ---------------------------------------------------------------------------
# Install ClawX: true | false
INSTALL_CLAWX=false

# ClawX version (leave empty for latest release)
CLAWX_VERSION=

# ---------------------------------------------------------------------------
# Network / Proxy
# ---------------------------------------------------------------------------
# HTTP(S) proxy (leave empty for direct connection)
HTTP_PROXY=
HTTPS_PROXY=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Log file path (relative to this project or absolute)
LOG_FILE=setup.log

# Verbose output: true | false
VERBOSE=false
