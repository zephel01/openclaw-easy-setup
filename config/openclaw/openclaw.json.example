{
  // openclaw-easy-setup — Configuration Reference
  //
  // This is a JSON5 format example. Copy to openclaw.json and edit as needed.
  // Most changes apply via hot reload (no restart required).
  // Only port/TLS changes require a restart.
  //
  // Editing methods:
  //   1. Web UI  — http://127.0.0.1:18789 → Config tab
  //   2. CLI     — openclaw config set <path> <value>
  //   3. Direct  — Edit this file

  gateway: {
    bind: "0.0.0.0",       // "0.0.0.0" inside Docker; "127.0.0.1" for native
    port: 18789,
    auth: {
      mode: "token",        // "token" | "none"
      // token: "your-64-char-hex-token",  // auto-generated by setup.sh
    },
  },

  messaging: {
    dmPolicy: "pairing",    // "pairing" | "open"
    requireMention: true,
  },

  tools: {
    deny: ["exec", "browser", "cron"],  // Denied by default for security
  },

  security: {
    sandboxInheritEnv: false,  // Do NOT pass host env vars to AI sandboxes
    allowedPaths: [
      "/home/openclaw/.openclaw",
      "/home/openclaw/data",
    ],
  },
}
